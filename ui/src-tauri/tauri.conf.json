{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "NONOS Ecosystem",
  "version": "1.0.5",
  "identifier": "systems.nonos.noxone",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' http://localhost:* https://*; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:*; style-src 'self' 'unsafe-inline' http://localhost:* https://*; img-src 'self' data: blob: http://localhost:* https://*; font-src 'self' data: http://localhost:* https://*; frame-src 'self' http://localhost:*; connect-src 'self' http://localhost:* https://*"
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "NONOS Ecosystem",
        "width": 1200,
        "center": true,
        "decorations": true,
        "transparent": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright (c) 2026 NON-OS",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "externalBin": ["binaries/anon", "binaries/anon-gencert"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "NONOS Ecosystem is a zero-trust privacy browser built on the Anyone Network. All traffic is routed through community-powered multi-hop encrypted relays with built-in NOX token wallet and node staking.",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "shortDescription": "Privacy-first trustless browser",
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
